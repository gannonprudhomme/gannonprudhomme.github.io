---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects } from "../data/projects";
---

<BaseLayout
  title="Gannon Prudhomme"
  description="Gannon Prudhomme is an iOS engineer at eero and hobbyist game developer."
>
  <section class="site-shell py-16 sm:py-24">
    <div class="space-y-12">
      <div class="max-w-3xl space-y-8">
        <div class="space-y-4">
          <h1 class="text-5xl font-bold leading-tight sm:text-6xl">Gannon Prudhomme</h1>
          <p class="text-xl leading-8 text-base-content/75">
            iOS engineer and hobbyist game developer.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="btn btn-outline" href="https://github.com/gannonprudhomme" target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/social/github.svg" alt="" />
            GitHub
          </a>
          <a class="btn btn-outline" href="https://linkedin.com/in/gannon-prudhomme" target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/social/linkedin.svg" alt="" />
            LinkedIn
          </a>
        </div>
      </div>

      <div class="project-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} compact />)}
      </div>
    </div>
  </section>
</BaseLayout>
